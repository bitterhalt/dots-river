#!/usr/bin/env bash
set -e

chosen=$(cut -d ';' -f1 ~/.local/share/emoji/emoji | bemenu_runner -B1 --bdr '#d02670' -l 15 -n -p "select emoji:" | sed "s/ .*//")

[ -z "$chosen" ] && exit

if [ -n "$1" ]; then
  wl-copy "$chosen"
else
  printf "$chosen" | wl-copy
  notify-send "$chosen Copied to clipboard!" &
fi
