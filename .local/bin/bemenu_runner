#!/usr/bin/env bash

BEMENU_ARGS=(-i
  -H '26'
  -P '*'
  --cw '2'
  --ch '18'
  --hp '8'
  --fn 'JetBrains Mono 16px'
  --tb '#161616' --tf '#78a9ff'
  --fb '#161616' --ff '#ffffff'
  --cb '#161616' --cf '#525252'
  --nb '#161616' --nf '#dde1e6'
  --ab '#161616' --af '#dde1e6'
  --hb '#161616' --hf '#be95ff'
  --bdr '#262626' --cf '#323232'
  --single-instance
  "$@")

if [ "$1" = 'run' ]; then
  bemenu-run "${BEMENU_ARGS[@]}"
else
  bemenu "${BEMENU_ARGS[@]}"
fi
