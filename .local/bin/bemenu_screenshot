#!/usr/bin/env bash

set -e

get_options() {
  echo "’ĆĮ  Record Screen (MP4)"
  echo "’ĆĮ  Record Region (MP4)"
  echo "’Ć░  Screenshot Full"
  echo "’Ć░  Screenshot Region"
  echo "’Ć░  Screenshot Full+delay"
  echo "’ŗō  Stop Recording"
}

main() {

  choice=$( (get_options) | bemenu_runner -n -B1 -p "Screenshot:" -l 6)

  if [[ -z "${choice// /}" ]]; then
    exit 1
  fi

  case $choice in
  '’ĆĮ  Record Screen (MP4)')
    wl-record -f
    ;;
  '’ĆĮ  Record Region (MP4)')
    wl-record -r
    ;;
  '’Ć░  Screenshot Full')
    wl-shot -f
    ;;
  '’Ć░  Screenshot Region')
    wl-shot -r
    ;;
  '’Ć░  Screenshot Full+delay')
    wl-shot -t
    ;;
  '’ŗō  Stop Recording')
    wl-record -k
    ;;
  esac
}

main &

exit 0
